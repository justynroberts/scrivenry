# Database
DATABASE_URL="file:/app/data/scrivenry.db"

# Authentication
# Generate a secure JWT secret (32+ chars): openssl rand -base64 32
JWT_SECRET="your-secret-key-here-min-32-chars"

# Security
AUTH_SECURE_COOKIES="true"

# CSRF Protection (optional, falls back to JWT_SECRET)
# Generate: openssl rand -base64 32
CSRF_SECRET="optional-csrf-secret-here"
